FROM golang:1.21-alpine AS builder

WORKDIR /app
COPY go.mod ./
# If there's a go.sum, uncomment below
# COPY go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o auth-service .

FROM alpine:latest
WORKDIR /root/
COPY --from=builder /app/auth-service .

EXPOSE 8080
CMD ["./auth-service"]
